# Database (Supabase PostgreSQL) ---------------------------------------------
# Pooler connection for Prisma Client (runtime queries)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection for Prisma Migrate / introspection
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App URL (used for absolute links — update when domain changes)
NEXT_PUBLIC_APP_URL="https://app.mymembersclub.com.br"
NEXT_PUBLIC_SITE_URL="https://app.mymembersclub.com.br"

# Email (Brevo) ---------------------------------------------------------------
BREVO_API_KEY="your-brevo-api-key"

# Auth ------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Members Club Webhook (Applyfy → Members Club subscription payments)
# Configure this same token in the Applyfy webhook panel
# Webhook URL: https://YOUR-DOMAIN/api/webhooks/members-club
# Events: TRANSACTION_PAID, TRANSACTION_CANCELED, TRANSACTION_REFUNDED, TRANSACTION_CHARGED_BACK
MEMBERS_CLUB_WEBHOOK_TOKEN="your-webhook-token"

# Applyfy Gateway (checkout for producer subscriptions)
APPLYFY_PUBLIC_KEY="your-public-key"
APPLYFY_SECRET_KEY="your-secret-key"
MEMBERS_CLUB_PRODUCT_ID="your-product-id-in-applyfy"

# Applyfy Checkout URL (link direto do produto criado no painel Applyfy)
MEMBERS_CLUB_CHECKOUT_URL="https://checkout.applyfy.com.br/checkout/YOUR_PRODUCT_ID?offer=YOUR_OFFER_CODE"
