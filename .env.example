# Database (Supabase PostgreSQL) ---------------------------------------------
# Pooler connection for Prisma Client (runtime queries)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection for Prisma Migrate / introspection
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App URL (used for absolute links — update when domain changes)
NEXT_PUBLIC_APP_URL="https://app.mymembersclub.com.br"
NEXT_PUBLIC_SITE_URL="https://app.mymembersclub.com.br"

# Email (Brevo) ---------------------------------------------------------------
BREVO_API_KEY="your-brevo-api-key"

# Auth ------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Encryption — REQUIRED: app won't boot without it (src/lib/encryption.ts throws)
# Encrypts/decrypts at-rest secrets. Use a long random string.
ENCRYPTION_SECRET="replace-with-a-long-random-string"

# Members Club Webhook (Applyfy → Members Club subscription payments)
# Configure this same token in the Applyfy webhook panel
# Webhook URL: https://YOUR-DOMAIN/api/webhooks/members-club
# Events: TRANSACTION_PAID, TRANSACTION_CANCELED, TRANSACTION_REFUNDED, TRANSACTION_CHARGED_BACK
MEMBERS_CLUB_WEBHOOK_TOKEN="your-webhook-token"

# Applyfy Gateway (checkout for producer subscriptions)
APPLYFY_PUBLIC_KEY="your-public-key"
APPLYFY_SECRET_KEY="your-secret-key"
MEMBERS_CLUB_PRODUCT_ID="your-product-id-in-applyfy"

# Applyfy Checkout URL (link direto do produto criado no painel Applyfy)
MEMBERS_CLUB_CHECKOUT_URL="https://checkout.applyfy.com.br/checkout/YOUR_PRODUCT_ID?offer=YOUR_OFFER_CODE"

# Web Push (VAPID) — browser push notifications
# Generate a keypair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:you@example.com"

# Rate limit — Upstash Redis (shared store) --------------------------
# Só em PRODUCTION. A AUSÊNCIA das duas vars = fallback automático pro
# rate-limit in-memory por-instância (2.4a) — ninguém é trancado fora.
# O par vem do painel Upstash (Redis database → REST API); é fetch-based,
# sem custo de HTTP client novo.
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Origin lockdown — modo-observação (2.4 Peça B.1) ------------------
# Segredo injetado pelo Cloudflare (Transform Rule) no header x-origin-lock.
# O servidor valida o VALOR (safeCompare); request sem o carimbo = observado.
# ⚠️ AUSÊNCIA não bloqueia nada (modo-observação): sem a env, tudo é registrado
# mas passa. O enforce (403) é a Peça B.2.
ORIGIN_LOCK_SECRET="a-long-random-secret-shared-with-the-cloudflare-transform-rule"
