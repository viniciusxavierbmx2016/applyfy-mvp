# Database (Supabase PostgreSQL) ---------------------------------------------
# Pooler connection for Prisma Client (runtime queries)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection for Prisma Migrate / introspection
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Auth ------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Members Club Webhook (Applyfy → Members Club subscription payments)
# Configure this same token in the Applyfy webhook panel
# Webhook URL: https://YOUR-DOMAIN/api/webhooks/members-club
# Events: TRANSACTION_PAID, TRANSACTION_CANCELED, TRANSACTION_REFUNDED, TRANSACTION_CHARGED_BACK
MEMBERS_CLUB_WEBHOOK_TOKEN="your-webhook-token"
