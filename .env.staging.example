# ============================================================================
# .env.staging.example — TEMPLATE do ambiente de STAGING (commitável)
# ----------------------------------------------------------------------------
# Copie para .env.staging (que é gitignored) e preencha com os valores REAIS do
# projeto de staging. NUNCA commite .env.staging — ele contém a service role key.
# Rodar o staging localmente:  npm run dev:staging
# (o dotenv-cli injeta estas vars no processo ANTES do Next subir, sobrepondo o
#  .env de produção sem tocá-lo.)
# ============================================================================

# Banco (Supabase PostgreSQL — projeto de STAGING) ---------------------------
# Pooler (Prisma Client, queries em runtime)
DATABASE_URL=postgresql://...pooler-do-staging...
# Conexão direta (Prisma Migrate / introspection)
DIRECT_URL=postgresql://...conexao-direta-do-staging...

# Supabase (projeto de staging: wxynnsyartxcvglqwmdw) ------------------------
NEXT_PUBLIC_SUPABASE_URL=https://wxynnsyartxcvglqwmdw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon-key-do-staging
SUPABASE_SERVICE_ROLE_KEY=service-role-do-staging

# URL do app (dev local apontando pro banco de staging) ----------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth -----------------------------------------------------------------------
NEXTAUTH_SECRET=qualquer-string-aleatoria

# Encryption (OBRIGATÓRIA — src/lib/encryption.ts lança erro se ausente) ------
# Pode reusar o valor do seu .env.local (só cifra/decifra segredos at-rest).
ENCRYPTION_SECRET=pode-reusar-o-local

# Email (Brevo) — necessário pra testar emails transacionais no staging ------
BREVO_API_KEY=key-real-para-testar-emails

# ----------------------------------------------------------------------------
# Deixados de FORA de propósito (não necessários pro escopo #5 de staging):
#   - VAPID_* (web push / notificações do navegador)
#   - APPLYFY_* + MEMBERS_CLUB_PRODUCT_ID / MEMBERS_CLUB_CHECKOUT_URL (checkout
#     e assinaturas de produtor)
#   - MEMBERS_CLUB_WEBHOOK_TOKEN (webhook Applyfy → Members Club)
#   - UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN (rate-limit shared store):
#     por design o staging usa o FALLBACK LOCAL (Map por-instância). Setar as duas
#     temporariamente APENAS pra exercitar o Redis real uma vez (2.4 Peça A).
# Adicione apenas se for exercitar esses fluxos no staging.
# ----------------------------------------------------------------------------
