generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  avatarUrl     String?
  role          Role      @default(STUDENT)
  points        Int       @default(0)
  level         Int       @default(1)
  workspaceId   String?
  phone           String?
  businessType    String?
  niche           String?
  monthlyRevenue  String?
  referralSource  String?
  document        String?
  themeConfig   String?   @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments      Enrollment[]
  progress         LessonProgress[]
  posts            Post[]
  comments         Comment[]
  lessonComments   LessonComment[]
  likes            Like[]
  sessions         Session[]
  notifications    Notification[]
  certificates     Certificate[]
  reviews          Review[]
  ownedCourses     Course[]         @relation("CourseOwner")
  ownedWorkspaces  Workspace[]      @relation("WorkspaceOwner")
  workspace        Workspace?       @relation("WorkspaceMembers", fields: [workspaceId], references: [id], onDelete: SetNull)
  collaborators    Collaborator[]
  subscriptions    Subscription[]
  quizAttempts     QuizAttempt[]

  @@index([workspaceId])
}

model Workspace {
  id             String   @id @default(uuid())
  slug           String   @unique
  name           String
  logoUrl        String?
  loginLayout       String  @default("central")
  loginBgImageUrl   String?
  loginBgColor      String? @default("#0a0a1a")
  loginPrimaryColor String? @default("#6366f1")
  loginLogoUrl      String?
  loginTitle        String?
  loginSubtitle     String?
  loginBoxColor     String? @default("#1a1a2e")
  loginBoxOpacity   Float?  @default(0.85)
  loginSideColor    String? @default("#0a0a1a")
  loginLinkColor    String? @default("#818cf8")
  faviconUrl     String?
  forceTheme     String?
  customDomain   String?  @unique
  masterPassword String?
  ownerId        String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner       User         @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     User[]       @relation("WorkspaceMembers")
  courses     Course[]
  webhookLogs WebhookLog[]
  collaborators Collaborator[]
  transactions ProducerTransaction[]

  @@index([ownerId])
}

enum Role {
  STUDENT
  PRODUCER
  ADMIN
  COLLABORATOR
}

model Collaborator {
  id          String              @id @default(uuid())
  email       String
  name        String?
  workspaceId String
  userId      String?
  permissions String[]
  courseIds   String[]
  status      CollaboratorStatus  @default(PENDING)
  invitedAt   DateTime            @default(now())
  acceptedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, email])
  @@index([userId])
  @@index([status])
}

enum CollaboratorStatus {
  PENDING
  ACCEPTED
  REVOKED
}


model Course {
  id                 String    @id @default(uuid())
  title              String
  slug               String    @unique
  description        String
  thumbnail          String?
  bannerUrl          String?
  checkoutUrl        String?
  price              Float?
  priceCurrency      String    @default("BRL")
  externalProductId  String?   @unique
  isPublished        Boolean   @default(false)
  showInStore        Boolean   @default(true)
  certificateEnabled Boolean   @default(true)
  communityEnabled   Boolean   @default(true)
  lessonCommentsEnabled Boolean @default(true)
  reviewsEnabled     Boolean   @default(true)
  gamificationEnabled Boolean  @default(true)
  showStudentCount   Boolean   @default(false)
  supportEmail       String?
  supportWhatsapp    String?
  showLessonSupport  Boolean   @default(true)
  memberBgColor       String?
  memberSidebarColor  String?
  memberHeaderColor   String?
  memberCardColor     String?
  memberPrimaryColor  String?
  memberTextColor     String?
  memberAccentColor   String?
  memberWelcomeText   String?
  memberLayoutStyle   String?  @default("netflix")
  order              Int       @default(0)
  ownerId            String?
  workspaceId        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  owner         User?         @relation("CourseOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  modules       Module[]
  sections      Section[]
  enrollments   Enrollment[]
  posts         Post[]
  certificates  Certificate[]
  reviews       Review[]
  menuItems     MenuItem[]

  @@index([ownerId])
  @@index([workspaceId])
  @@index([isPublished])
}

model MenuItem {
  id        String   @id @default(uuid())
  courseId  String
  label     String
  icon      String   @default("link")
  url       String
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Settings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Module {
  id             String    @id @default(uuid())
  title          String
  order          Int       @default(0)
  daysToRelease  Int       @default(0)
  releaseAt      DateTime?
  thumbnailUrl   String?
  hideTitle      Boolean   @default(false)
  sectionId      String?
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section        Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  lessons   Lesson[]

  @@index([sectionId])
  @@index([courseId, order])
}

model Section {
  id        String   @id @default(uuid())
  title     String
  order     Int      @default(0)
  courseId  String
  createdAt DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  modules   Module[]

  @@index([courseId])
}

model Lesson {
  id             String   @id @default(uuid())
  title          String
  description    String?
  videoUrl       String
  duration       Int?
  order          Int      @default(0)
  daysToRelease  Int      @default(0)
  moduleId       String
  module         Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  progress    LessonProgress[]
  comments    LessonComment[]
  materials   LessonMaterial[]
  quiz        Quiz?

  @@index([moduleId, order])
}

model Enrollment {
  id        String           @id @default(uuid())
  userId    String
  courseId   String
  status    EnrollmentStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime         @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  overrides EnrollmentOverride[]

  @@unique([userId, courseId])
  @@index([expiresAt])
  @@index([status])
  @@index([courseId, status])
}

model EnrollmentOverride {
  id           String   @id @default(uuid())
  enrollmentId String
  moduleId     String?
  lessonId     String?
  released     Boolean  @default(true)
  createdAt    DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, moduleId])
  @@unique([enrollmentId, lessonId])
  @@index([moduleId])
  @@index([lessonId])
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  completed      Boolean   @default(false)
  completedAt    DateTime?
  lastAccessedAt DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, lastAccessedAt])
}

model Post {
  id        String   @id @default(uuid())
  content   String
  type      PostType @default(FREE)
  pinned    Boolean  @default(false)
  userId    String
  courseId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]

  @@index([courseId, createdAt])
  @@index([userId])
}

enum PostType {
  QUESTION
  RESULT
  FEEDBACK
  FREE
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model LessonComment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  lessonId  String
  parentId  String?
  createdAt DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent    LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   LessonComment[] @relation("CommentReplies")

  @@index([parentId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, read, createdAt])
}

enum NotificationType {
  LIKE
  COMMENT
  REPLY
  ENROLLMENT
  LEVEL_UP
}

model Certificate {
  id         String   @id @default(uuid())
  code       String   @unique
  userId     String
  courseId   String
  issuedAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
}

model WebhookLog {
  id                String            @id @default(uuid())
  event             String
  email             String?
  productExternalId String?
  courseId          String?
  workspaceId       String?
  status            WebhookLogStatus
  errorMessage      String?
  rawPayload        Json
  createdAt         DateTime          @default(now())

  workspace         Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([createdAt])
  @@index([workspaceId])
}

enum WebhookLogStatus {
  SUCCESS
  ERROR
  IGNORED
}

model ProducerTransaction {
  id            String   @id @default(uuid())
  workspaceId   String
  userId        String?
  courseId       String?
  amount        Float
  currency      String   @default("BRL")
  status        String
  paymentMethod String?
  externalId    String?  @unique
  customerEmail String?
  customerName  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

model LessonMaterial {
  id        String   @id @default(uuid())
  lessonId  String
  name      String
  fileName  String
  fileUrl   String
  fileSize  Int
  fileType  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model IntegrationRequest {
  id        String                   @id @default(uuid())
  gateway   String
  email     String
  notes     String?
  status    IntegrationRequestStatus @default(PENDING)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@index([createdAt])
  @@index([status])
}

enum IntegrationRequestStatus {
  PENDING
  REVIEWING
  COMPLETED
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  device    String?
  ip        String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Subscription billing ───────────────────────────────────────

model Plan {
  id                    String   @id @default(uuid())
  name                  String
  slug                  String   @unique
  price                 Float
  currency              String   @default("BRL")
  interval              String   @default("monthly")
  maxWorkspaces         Int      @default(10)
  maxCoursesPerWorkspace Int     @default(30)
  features              String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(PENDING)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  suspendedAt        DateTime?
  externalId         String?            @unique
  exempt             Boolean            @default(false)
  exemptReason       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
}

model Invoice {
  id             String        @id @default(uuid())
  subscriptionId String
  amount         Float
  currency       String        @default("BRL")
  status         InvoiceStatus @default(PENDING)
  externalId     String?       @unique
  paidAt         DateTime?
  refundedAt     DateTime?
  failedAt       DateTime?
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model PlatformSettings {
  id         String   @id @default("platform")
  logoUrl    String?
  faviconUrl String?
  updatedAt  DateTime @updatedAt
}

model Quiz {
  id           String   @id @default(uuid())
  lessonId     String   @unique
  title        String?
  passingScore Int      @default(70)
  showAnswers  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id        String   @id @default(uuid())
  quizId    String
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]

  @@index([quizId])
}

model QuizOption {
  id         String  @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id        String   @id @default(uuid())
  quizId    String
  userId    String
  score     Float
  passed    Boolean
  answers   String
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@index([quizId, userId])
}
