{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/cron/automations",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/pending",
      "schedule": "*/10 * * * *"
